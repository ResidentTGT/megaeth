{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/**/*.ts",
    "shared/src/**/*.ts",
    "backend/src/**/*.ts",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "backend/dist",
    "frontend/dist",
    "shared/dist"
  ]
}
